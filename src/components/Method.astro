      <table class="w-full text-left border-collapse select-none">
        <thead>
          <tr class="border-b border-white/10 bg-white/[0.02]">
            <th class="p-6 text-xs font-bold tracking-widest text-[#737373] uppercase">SERVICIO</th>
            <th class="p-6 text-xs font-bold tracking-widest text-[#737373] uppercase">GYM TRADICIONAL</th>
            <!-- Highlighted Header -->
            <th class="p-6 text-xs font-bold tracking-widest text-white uppercase bg-white/[0.05] border-l border-r border-white/10 relative shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]">
              IMPULSA FIT
              <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-white/40 to-transparent"></div>
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/[0.05] text-sm">
          
          <tr class="hover:bg-white/[0.01] transition-colors duration-150">
            <td class="p-6 font-bold text-white uppercase tracking-wide text-xs">Coaches en Sala</td>
            <td class="p-6 text-[#737373] font-light">1 profesor para 50+ personas</td>
            <td class="p-6 text-white font-medium bg-white/[0.03] border-l border-r border-white/5">Máximo 3 alumnos por Coach</td>
          </tr>

          <tr class="hover:bg-white/[0.01] transition-colors duration-150">
            <td class="p-6 font-bold text-white uppercase tracking-wide text-xs">Planificación de Fuerza</td>
            <td class="p-6 text-[#737373] font-light">Rutina estandarizada igual para todos</td>
            <td class="p-6 text-white font-medium bg-white/[0.03] border-l border-r border-white/5">Estructura 100% individual</td>
          </tr>

