---
// Boutique.astro - Details about the high-end boutique experience and photo gallery
import { Image } from 'astro:assets';

// Import images from assets to trigger Astro's optimization service
import loungeImg from '../assets/images/IMG_8707.JPG';
import lockerImg from '../assets/images/IMG_9709.JPG';
import floorImg from '../assets/images/IMG_7376.JPG';
import equipImg from '../assets/images/IMG_8014.JPG';
import detailImg from '../assets/images/IMG_7590.JPG';
import nutritionImg from '../assets/images/IMG_8118.jpeg';
---

<section id="boutique" class="py-24 bg-[#0c0c0e] border-b border-[#ffffff0a] relative">
  <div class="max-w-6xl mx-auto px-6">
    
    <!-- Heading -->
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <span class="text-xs font-bold tracking-widest text-[#737373] uppercase mb-4 block">Servicio Exclusivo</span>
      <h2 class="text-3xl md:text-5xl font-black italic tracking-tight mb-4 uppercase">
        Experiencia <span class="text-metallic font-black">Boutique</span>
      </h2>
      <p class="text-base text-[#a3a3a3] font-light">
        El entrenamiento es solo el inicio. Cada detalle en Impulsa Fit está diseñado para entregarte comodidad, privacidad y un estándar superior.
      </p>
    </div>

    <!-- Gallery / Feature grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-20">
      
      <!-- Text features -->
      <div class="space-y-8 reveal">
        
        <div class="flex gap-4">
          <span class="flex-shrink-0 w-12 h-12 rounded border border-[#ffffff15] bg-[#0b0b0b] flex items-center justify-center text-white">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </span>
          <div>
            <h3 class="text-lg font-bold text-white mb-2 uppercase">Espacio Impecable y Privado</h3>
            <p class="text-sm text-[#737373] font-light leading-relaxed">
              Olvídate de las salas llenas. Nuestro aforo es estrictamente controlado y la limpieza es una obsesión. Entrena en un ambiente tranquilo y enfocado.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="flex-shrink-0 w-12 h-12 rounded border border-[#ffffff15] bg-[#0b0b0b] flex items-center justify-center text-white">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72M6.75 18h3.5a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75v3.75c0 .414.336.75.75.75z" />
            </svg>
          </span>
          <div>
            <h3 class="text-lg font-bold text-white mb-2 uppercase">Amenidades VIP</h3>
            <p class="text-sm text-[#737373] font-light leading-relaxed">
              Disfruta de café espresso, agua purificada fría, un milo caliente, té y toallas desinfectantes en cada sesión. Todo listo para que te concentres solo en tu progreso.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="flex-shrink-0 w-12 h-12 rounded border border-[#ffffff15] bg-[#0b0b0b] flex items-center justify-center text-white">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v6m0 0a4 4 0 0 0 4 4h1a1 1 0 0 1 1 1v1m0 0a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2v-1a1 1 0 0 1 1-1h1a4 4 0 0 0 4-4Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v1m3-1v1m3-1v1" />
            </svg>
          </span>
          <div>
            <h3 class="text-lg font-bold text-white mb-2 uppercase">Lockers & ducha privada</h3>
            <p class="text-sm text-[#737373] font-light leading-relaxed">
              Contamos con casilleros de seguridad y ducha completamente equipados con shampoo, acondicionador, jabón y secador de pelo para que puedas volver a tus actividades diarias de inmediato.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="flex-shrink-0 w-12 h-12 rounded border border-[#ffffff15] bg-[#0b0b0b] flex items-center justify-center text-white">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.75 9.75H20.25M9.75 4.75V20.25M14.25 4.75V20.25" />
            </svg>
          </span>
          <div>
            <h3 class="text-lg font-bold text-white mb-2 uppercase">Gimnasio & Nutricionista Integrado</h3>
            <p class="text-sm text-[#737373] font-light leading-relaxed">
              Acceso a la sala de fuerza incluido en tu membresía, complementado con evaluaciones nutricionales para ajustar tu alimentación al entrenamiento.
            </p>
          </div>
        </div>

      </div>

      <!-- Single Highlight Gallery Box -->
      <div class="reveal delay-100">
        <div class="premium-card p-3 border-[#ffffff15] rounded-xl overflow-hidden aspect-[4/3] relative group">
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent z-10 pointer-events-none"></div>
          <Image 
            src={loungeImg} 
            alt="Lounge y Cafetería Impulsa Fit" 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            width={700}
            format="webp"
          />
          <div class="absolute bottom-6 left-6 right-6 z-20">
            <span class="text-xs font-bold tracking-widest text-[#a3a3a3] uppercase block mb-1">El Estándar Impulsa</span>
            <p class="text-lg text-white font-black italic tracking-wide uppercase">Área de Bienvenida y Cafetería</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Interactive Carousel Gallery of Sede Photos -->
    <div class="reveal delay-200">
      <h3 class="text-xl font-bold tracking-tight text-white mb-6 uppercase text-center md:text-left">Galería de Sede Concepción</h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        
        <!-- Photo 1 -->
        <div class="premium-card border-[#ffffff0a] aspect-[4/3] rounded-lg overflow-hidden relative group cursor-pointer">
          <Image src={floorImg} alt="Sala de fuerza" class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105" width={300} format="webp" />
          <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
            <span class="text-xs font-bold tracking-widest border border-white px-2 py-1 rounded">SALA FUERZA</span>
          </div>
        </div>

        <!-- Photo 2 -->
        <div class="premium-card border-[#ffffff0a] aspect-[4/3] rounded-lg overflow-hidden relative group cursor-pointer">
          <Image src={lockerImg} alt="Ducha y Casilleros" class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105" width={300} format="webp" />
          <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
            <span class="text-xs font-bold tracking-widest border border-white px-2 py-1 rounded">CASILLEROS / DUCHA</span>
          </div>
        </div>

        <!-- Photo 3 -->
        <div class="premium-card border-[#ffffff0a] aspect-[4/3] rounded-lg overflow-hidden relative group cursor-pointer">
          <Image src={equipImg} alt="Equipamiento" class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105" width={300} format="webp" />
          <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
            <span class="text-xs font-bold tracking-widest border border-white px-2 py-1 rounded">EQUIPOS</span>
          </div>
        </div>

        <!-- Photo 4 -->
        <div class="premium-card border-[#ffffff0a] aspect-[4/3] rounded-lg overflow-hidden relative group cursor-pointer">
          <Image src={detailImg} alt="Detalles Boutique" class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105" width={300} format="webp" />
          <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
            <span class="text-xs font-bold tracking-widest border border-white px-2 py-1 rounded">RECEPCIÓN</span>
          </div>
        </div>

        <!-- Photo 5 -->
        <div class="premium-card border-[#ffffff0a] aspect-[4/3] rounded-lg overflow-hidden relative group cursor-pointer col-span-2 md:col-span-1">
          <Image src={nutritionImg} alt="Evaluación Antropométrica" class="w-full h-full object-cover transition-all duration-500 group-hover:scale-105" width={300} format="webp" />
          <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
            <span class="text-xs font-bold tracking-widest border border-white px-2 py-1 rounded">NUTRICIÓN</span>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>
