<!-- Billing Selector Controller Script -->
<script>
  function initMemberships() {
    const toggleBtn = document.getElementById('billing-toggle');
    if (!toggleBtn) return; // Prevent errors if component isn't on the page

    const toggleKnob = document.getElementById('toggle-knob');
    const labelPlus = document.getElementById('label-plus');
    const labelStandard = document.getElementById('label-standard');
    
    // Price span targets
    const priceSalud = document.getElementById('price-salud');
    const priceBasico = document.getElementById('price-basico');
    const priceBienestar = document.getElementById('price-bienestar');
    
    // Description elements
    const descSalud = document.getElementById('desc-salud');
    const descBasico = document.getElementById('desc-basico');
    const descBienestar = document.getElementById('desc-bienestar');
    
    // Text features that change
    const agendamientoSalud = document.getElementById('agendamiento-salud');
    const agendamientoBasico = document.getElementById('agendamiento-basico');
    const agendamientoBienestar = document.getElementById('agendamiento-bienestar');
    
    // Congelar features
    const congelarSaludLi = document.getElementById('congelar-salud-li');
    const congelarBienestarLi = document.getElementById('congelar-bienestar-li');
    const congelarSalud = document.getElementById('congelar-salud');
    const congelarBienestar = document.getElementById('congelar-bienestar');
    
    // Buttons (Fiti Checkout links)
    const btnSalud = document.getElementById('btn-salud');
    const btnBasico = document.getElementById('btn-basico');
    const btnBienestar = document.getElementById('btn-bienestar');
    
    // Footnote text
    const termsNotes = document.getElementById('terms-notes');

    let isStandard = false; // Starts in PLUS (Semestral)

    function updatePrices() {
      if (isStandard) {
        // Toggle animation: move knob to right
        toggleKnob?.classList.add('translate-x-8');
        toggleKnob?.classList.remove('translate-x-0');
        
        // Active label colors
        labelStandard?.classList.add('text-white');
        labelStandard?.classList.remove('text-[#737373]');
        labelPlus?.classList.add('text-[#737373]');
        labelPlus?.classList.remove('text-white');

        // Set Standard prices
        if (priceSalud) priceSalud.textContent = '159.990';
        if (priceBasico) priceBasico.textContent = '179.990';
        if (priceBienestar) priceBienestar.textContent = '189.990';

        // Set Standard descriptions
        if (descSalud) descSalud.textContent = 'Sin fidelidad · Cancela cuando quieras sin penalizaciones';
        if (descBasico) descBasico.textContent = 'Sin fidelidad · Cancela cuando quieras sin penalizaciones';
        if (descBienestar) descBienestar.textContent = 'Sin fidelidad · Cancela cuando quieras sin penalizaciones';

        // Set Standard features (Standard Scheduling)
        if (agendamientoSalud) agendamientoSalud.innerHTML = 'Agendamiento standard vía Fiti';
        if (agendamientoBasico) agendamientoBasico.innerHTML = 'Agendamiento standard vía Fiti';
        if (agendamientoBienestar) agendamientoBienestar.innerHTML = 'Agendamiento standard vía Fiti';

        // Set Standard congelar features (opacity reduction / block)
        if (congelarSaludLi) congelarSaludLi.classList.add('opacity-40');
        if (congelarSalud) congelarSalud.innerHTML = '<del>Permite congelar hasta 15 días</del>';
        
        if (congelarBienestarLi) congelarBienestarLi.classList.add('opacity-40');
        if (congelarBienestar) congelarBienestar.innerHTML = '<del>Permite congelar hasta 1 mes</del>';

        // Update Checkout URLs to STANDARD (Monthly)
        if (btnSalud) btnSalud.href = 'https://es.fiti.app/impulsafit/1/page/landing-page/checkout/35/0';
        if (btnBasico) btnBasico.href = 'https://es.fiti.app/impulsafit/1/page/landing-page/checkout/37/0';
        if (btnBienestar) btnBienestar.href = 'https://es.fiti.app/impulsafit/1/page/landing-page/checkout/36/0';

        // Update footer terms note
        if (termsNotes) {
          termsNotes.innerHTML = '* La membresía <strong>STANDARD (Mensual)</strong> no tiene permanencia mínima ni penalizaciones. Se renueva automáticamente de forma mensual hasta que decidas darla de baja desde tu perfil de usuario.';
        }
      } else {
        // Toggle animation: move knob to left
        toggleKnob?.classList.add('translate-x-0');
        toggleKnob?.classList.remove('translate-x-8');
        
        // Active label colors
        labelPlus?.classList.add('text-white');
        labelPlus?.classList.remove('text-[#737373]');
        labelStandard?.classList.add('text-[#737373]');
        labelStandard?.classList.remove('text-white');

        // Set Plus prices
        if (priceSalud) priceSalud.textContent = '134.990';
        if (priceBasico) priceBasico.textContent = '154.990';
        if (priceBienestar) priceBienestar.textContent = '164.990';

        // Set Plus descriptions
        if (descSalud) descSalud.textContent = 'Ahorras $25.000 CLP cada mes · Pago automático recurrente';
        if (descBasico) descBasico.textContent = 'Ahorras $25.000 CLP cada mes · Pago automático recurrente';
        if (descBienestar) descBienestar.textContent = 'Ahorras $25.000 CLP cada mes · Pago automático recurrente';

        // Set Plus features (Priority Scheduling)
        if (agendamientoSalud) agendamientoSalud.innerHTML = '<strong>Agendamiento Priority</strong> vía Fiti';
        if (agendamientoBasico) agendamientoBasico.innerHTML = '<strong>Agendamiento Priority</strong> vía Fiti';
        if (agendamientoBienestar) agendamientoBienestar.innerHTML = '<strong>Agendamiento Priority</strong> vía Fiti';

        // Restore congelar features
        if (congelarSaludLi) congelarSaludLi.classList.remove('opacity-40');
        if (congelarSalud) congelarSalud.innerHTML = 'Permite congelar hasta 15 días';
        
        if (congelarBienestarLi) congelarBienestarLi.classList.remove('opacity-40');
        if (congelarBienestar) congelarBienestar.innerHTML = 'Permite congelar hasta 1 mes';

        // Update Checkout URLs to PLUS (Semestral)
        if (btnSalud) btnSalud.href = 'https://es.fiti.app/impulsafit/1/page/landing-page/checkout/34/0';
        if (btnBasico) btnBasico.href = 'https://es.fiti.app/impulsafit/1/page/landing-page/checkout/32/0';
        if (btnBienestar) btnBienestar.href = 'https://es.fiti.app/impulsafit/1/page/landing-page/checkout/33/0';

        // Update footer terms note
        if (termsNotes) {
          termsNotes.innerHTML = '* La membresía <strong>PLUS (Semestral)</strong> tiene una permanencia mínima de 6 meses con cargo mensual automático. En caso de retiro anticipado, aplica una penalización del 25% sobre el saldo pendiente de las mensualidades restantes.';
        }
      }
    }

    // Toggle click listeners
    toggleBtn.addEventListener('click', () => {
      isStandard = !isStandard;
      updatePrices();
    });

    labelPlus?.addEventListener('click', () => {
      if (isStandard) {
        isStandard = false;
        updatePrices();
      }
    });

    labelStandard?.addEventListener('click', () => {
      if (!isStandard) {
        isStandard = true;
        updatePrices();
      }
    });
  }

  // Bind to initial load and page changes
  initMemberships();
  document.addEventListener('astro:page-load', initMemberships);
</script>
