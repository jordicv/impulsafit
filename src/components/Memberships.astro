---
// Memberships.astro - Interactive memberships grid with toggle
---

<section id="membresias" class="py-24 bg-black relative border-b border-[#ffffff0a]">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Heading -->
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <span class="inline-block text-xs font-bold tracking-widest text-[#737373] border border-[#ffffff08] px-3 py-1 rounded bg-[#0b0b0b] mb-4 uppercase">
        Escoge tu Estructura
      </span>
      <h2 class="text-3xl md:text-5xl font-black italic tracking-tight mb-4 uppercase">
        Membresías <span class="text-metallic font-black">Impulsa</span>
      </h2>
      <p class="text-base md:text-lg text-[#a3a3a3] font-light">
        Elige la membresía y la modalidad que mejor se adapte a tus objetivos. Nuestras membresías te entregan estructura completa, acompañamiento profesional continuo y acceso exclusivo.
      </p>
    </div>

    <!-- Toggle Selector (Semestral vs Mensual) -->
    <div class="flex justify-center items-center gap-4 mb-16 reveal delay-100">
      <span class="text-sm font-bold tracking-wider cursor-pointer transition-colors duration-200 select-none text-white" id="label-plus">
        PLUS <span class="text-[10px] bg-white text-black px-1.5 py-0.5 rounded font-black ml-1">SEMESTRAL</span>
      </span>
      
      <!-- Switch Toggle -->
      <button 
        id="billing-toggle" 
        class="w-16 h-8 bg-neutral-800 rounded-full p-1 relative transition-colors duration-300 focus:outline-none"
        aria-label="Alternar periodicidad de cobro"
      >
        <span class="block w-6 h-6 bg-white rounded-full transition-transform duration-300 transform translate-x-0" id="toggle-knob"></span>
      </button>

      <span class="text-sm font-bold tracking-wider cursor-pointer transition-colors duration-200 select-none text-[#737373]" id="label-standard">
        STANDARD <span class="text-[10px] border border-[#ffffff15] text-[#a3a3a3] px-1.5 py-0.5 rounded font-bold ml-1">MENSUAL</span>
      </span>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
      
      <!-- CARD 1: SALUD (8 Sesiones/mes) -->
      <div class="premium-card flex flex-col justify-between p-8 group reveal delay-100">
        <div>
          <div class="flex justify-between items-start mb-6">
            <div>
              <h3 class="text-2xl font-bold tracking-tight text-white mb-1">MEMBRESÍA SALUD</h3>
              <p class="text-xs font-bold text-[#737373] tracking-widest uppercase">8 Sesiones con Coach/Mes</p>
            </div>
            <!-- Icon -->
            <span class="p-2.5 rounded bg-neutral-900 border border-[#ffffff0a]">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-[#a3a3a3]">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
            </span>
          </div>

          <!-- Price Display -->
          <div class="mb-8">
            <div class="flex items-baseline text-white">
              <span class="text-xl font-bold tracking-tight">$</span>
              <!-- Plus Price -->
              <span class="text-5xl font-black italic tracking-tighter transition-all duration-300" id="price-salud">134.990</span>
              <span class="text-sm font-semibold text-[#737373] ml-2">/ mes</span>
            </div>
            <p class="text-xs text-[#737373] mt-2" id="desc-salud">Ahorras $25.000 CLP cada mes · Pago automático recurrente</p>
          </div>

          <hr class="border-[#ffffff0a] mb-8" />

          <!-- Features -->
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-white flex-shrink-0 mt-0.5">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm text-[#e5e5e5]"><strong>8 sesiones</strong> de fuerza al mes</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-white flex-shrink-0 mt-0.5">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm text-[#e5e5e5]"><strong>1 sesión</strong> de masoterapia mensual</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-white flex-shrink-0 mt-0.5">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm text-[#e5e5e5]">Rutina personalizada en tu celular</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-white flex-shrink-0 mt-0.5">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm text-[#e5e5e5]" id="agendamiento-salud">Agendamiento Priority vía Fiti</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-white flex-shrink-0 mt-0.5">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm text-[#e5e5e5]">Acceso libre a Gimnasio / Sala</span>
            </li>
            <li class="flex items-start gap-3 text-neutral-500" id="congelar-salud-li">
