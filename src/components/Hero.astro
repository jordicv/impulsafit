---
// Hero.astro - Premium video hero component styled after Benthic OPS
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-black pt-20">
  
  <!-- Video Background Wrapper -->
  <div class="absolute inset-0 w-full h-full overflow-hidden select-none z-0">
    <video
      muted
      loop
      playsinline
      preload="none"
      poster="/images/poster-sede.webp"
      id="hero-bg-video"
      class="w-full h-full object-cover"
      style="opacity: 0.35; filter: brightness(0.7) contrast(1.1); transition: opacity 1.2s ease-in-out;"
    >
      <source src="/videos/hero-bg.webm" type="video/webm" />
      <source src="/videos/hero-bg.mp4" type="video/mp4" />
    </video>
  </div>

  <!-- Ambient Dark Overlay (Top, center, bottom shading) -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/20 to-black z-10 pointer-events-none"></div>

  <!-- Hero Content -->
  <div class="max-w-6xl mx-auto px-6 w-full relative z-20 pt-16 pb-12">
    <div class="max-w-3xl">
      <!-- Badge / Slogan Label -->
      <span class="inline-block text-xs md:text-sm font-bold tracking-widest text-[#a3a3a3] border border-[#ffffff15] px-3.5 py-1.5 rounded bg-black/40 backdrop-blur-md mb-6 uppercase">
        Entrenamiento Boutique · Concepción
      </span>

      <!-- Main Headline in Barlow Condensed 900 Italic -->
      <h1 class="text-4xl md:text-7xl font-black italic tracking-tight leading-[0.9] text-white mb-6 uppercase">
        Aquí no vienes a entrenar.<br />
        <span class="text-metallic font-black">Vienes a lograr</span> lo que antes no pudiste solo.
      </h1>

      <!-- Copy Paragraph in Barlow -->
      <p class="text-lg md:text-xl text-[#d4d4d4] font-light leading-relaxed mb-10 max-w-2xl">
        Si no has podido ser constante entrenando solo, aquí tienes un sistema clínico y de acompañamiento real que te sostiene en cada sesión.
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-5 items-stretch sm:items-center">
        <a href="https://es.fiti.app/impulsafit/1/page/landing-page/agenda" target="_blank" rel="noopener noreferrer" class="btn-platinum text-center">
          Agendar Sesión de Prueba
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </a>
        <a href="/servicio#membresias" class="btn-outline text-center">
          Ver Membresías
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom transition gradient to background -->
  <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-black to-transparent pointer-events-none z-10"></div>
</section>

<!-- Benthic OPS Video Controller Script -->
<script>
  (function() {
    const video = document.getElementById('hero-bg-video') as HTMLVideoElement;
    if (!video) return;

    // Cinematic slow motion speed
    video.playbackRate = 0.55;

    // Play only when visible to optimize CPU/GPU/battery
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduceMotion) {
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        }
      }, { threshold: 0.1 });
      io.observe(video);
    }

    let fadingOut = false;

    // Smooth loop transitions (fading out before the end to avoid jumps)
    video.addEventListener('timeupdate', () => {
      const duration = video.duration;
      const currentTime = video.currentTime;

      if (!duration) return;

      // Start fade out 1.3s before video ends
      if (currentTime > duration - 1.3 && !fadingOut) {
        fadingOut = true;
        video.style.opacity = '0.02';
      }
      
      // Reset opacity back to normal once loop starts
      if (currentTime < 0.8 && fadingOut) {
        fadingOut = false;
        video.style.opacity = '0.35';
      }
    });

    // Handle manual seeks or loop triggers to reset fade state
    video.addEventListener('seeked', () => {
      if (video.currentTime < 1) {
        fadingOut = false;
        video.style.opacity = '0.35';
      }
    });
  })();
</script>
